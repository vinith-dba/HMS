# --- Secrets — never commit real env files ---
.env
.env.*
!.env.example

# --- Patient data — never commit, never serve statically ---
/storage/
/public/uploads/

# --- Dependencies ---
node_modules
/.pnp
.pnp.*

# --- Next.js build output ---
/.next/
/out/
/build
next-env.d.ts

# --- Prisma generated client ---
/src/generated/
/prisma/generated/

# --- Testing ---
/coverage

# --- Logs & debug ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# --- OS / editor ---
.DS_Store
Thumbs.db
*.pem
.vscode/*
!.vscode/extensions.json
.idea

# --- Vercel ---
.vercel

# --- TypeScript ---
*.tsbuildinfo
